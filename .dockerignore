# Dependencies
/node_modules
/vendor

# Environment
.env
.env.backup
.env.production

# Git
.git
.gitattributes
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
/tests
phpunit.xml
